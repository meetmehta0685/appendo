# Supabase PostgreSQL Async connection URL
# Form connection pooler string (Port 5432 or 6543)
# Format: postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@[POOLER_HOST]:5432/postgres
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:your-supabase-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
